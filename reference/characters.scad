function get_character(name) =
    name == "invader" ? _invader :
    name == "ghost" ? _ghost :
    name == "monster" ? _monster :
    name == "specter" ? _specter :
    name == "phantom" ? _phantom :
    name == "crab" ? _crab :
    name == "claude" ? _claude :
    name == "foo" ? _foo :
    _bar;

